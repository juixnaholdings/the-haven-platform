POSTGRES_DB=the_haven
POSTGRES_USER=the_haven
POSTGRES_PASSWORD=replace-with-real-db-password

DATABASE_URL=postgresql://the_haven:replace-with-real-db-password@db:5432/the_haven

SECRET_KEY=replace-with-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.production

ALLOWED_HOSTS=your-domain.com
USE_X_FORWARDED_HOST=True

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

AUTH_REFRESH_COOKIE_NAME=__Host-refresh
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_PATH=/

SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
HSTS_HEADER_MAX_AGE=3600

SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

APP_DOMAIN=your-domain.com

HTTP_PORT=80
HTTPS_PORT=443

LETSENCRYPT_DIR=/etc/letsencrypt
CERTBOT_WEBROOT=/var/www/certbot

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

ENABLE_SUPERUSER_SEED=False
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
