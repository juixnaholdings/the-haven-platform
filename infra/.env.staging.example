# Staging source-of-truth env file for docker compose. Do not duplicate these values
# into backend/.env on the server; staging manage.py commands run through Compose.
COMPOSE_PROJECT_NAME=the-haven-staging
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=replace-with-a-long-random-value
JWT_SIGNING_KEY=replace-with-a-different-long-random-value
ALLOWED_HOSTS=staging.example.com
CORS_ALLOWED_ORIGINS=https://staging.example.com
CSRF_TRUSTED_ORIGINS=https://staging.example.com
DATABASE_URL=postgresql://the_haven:replace-db-password@db:5432/the_haven
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True
TIME_ZONE=UTC
API_PREFIX=api

POSTGRES_DB=the_haven
POSTGRES_USER=the_haven
POSTGRES_PASSWORD=replace-db-password

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
USE_X_FORWARDED_HOST=True

AUTH_REFRESH_COOKIE_NAME=__Host-refresh
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_PATH=/
AUTH_REFRESH_COOKIE_DOMAIN=

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
STAGING_HTTP_PORT=80
STAGING_BASE_URL=https://staging.example.com

# Optional bootstrap values. Only set them when intentionally creating an admin user.
ENABLE_SUPERUSER_SEED=False
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
